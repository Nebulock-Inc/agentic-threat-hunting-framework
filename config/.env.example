# Splunk MCP Configuration
SPLUNK_HOST=your-splunk-host
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-splunk-token-here
SPLUNK_SCHEME=https

# LLM Provider (choose one - auto-detected if not set)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# AWS_PROFILE=default
# OLLAMA_HOST=http://localhost:11434

# ATHF LLM Settings (optional overrides)
# ATHF_LLM_PROVIDER=openai
# ATHF_LLM_MODEL=gpt-4o

# Web Search (for research agent)
# TAVILY_API_KEY=tvly-...
